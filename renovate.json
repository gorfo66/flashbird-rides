{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchDatasources": ["npm"],
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "matchDatasources": ["npm"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "groupName": "Angular and related packages",
      "automerge": false,
      "matchPackageNames": ["/@angular.*/", "/angular-eslint/", "/@ngrx.*/"]
    }
  ],
  "npm": {},
  "schedule": [
    "after 3am on Monday"
  ],
  "semanticCommits": "enabled",
  "semanticCommitScope": "deps",
  "prConcurrentLimit": 5,
  "prCreation": "auto",
  "vulnerabilityAlerts": {
    "enabled": true
  }
}
