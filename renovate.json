{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base"
  ],
  "packageRules": [
    {
      "matchDatasources": ["npm"],
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "matchDatasources": ["npm"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "matchPackagePatterns": ["@angular*", "angular-eslint", "@ngrx*"],
      "groupName": "Angular and related packages",
      "automerge": false
    }
  ],
  "npm": {
    "supportPolicy": ["active"]
  },
  "schedule": [
    "after 3am on Monday"
  ],
  "semanticCommits": "enabled",
  "semanticCommitScope": "deps",
  "prConcurrentLimit": 5,
  "prCreation": "auto",
  "vulnerabilityAlerts": {
    "enabled": true
  },
  "requiredStatusChecks": ["Build and Test"],
  "automergeWaitForStatus": "all"
}
